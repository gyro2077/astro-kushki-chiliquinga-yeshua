---
import HeaderAuth from "../components/HeaderAuth";
import SearchBarMini from "../components/SearchBarMini";
import Chatbot from "../components/Chatbot";
import "../styles/fonts.css";
import "../styles/global.css";

const { title = "Aether-Fi Docs" } = Astro.props;
---
<!doctype html>
<html class="dark" lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Portal de exploracion interdimensional con Astro" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-bg-main text-text-primary min-h-screen flex flex-col font-body-md overflow-x-hidden selection:bg-ai-cyan selection:text-bg-main pt-16">
    <header class="fixed top-0 w-full z-50 bg-surface-container/80 backdrop-blur-xl border-b border-white/10 shadow-[0_4px_30px_rgba(0,0,0,0.1)]">
      <div class="flex justify-between items-center px-grid-gutter h-16 w-full max-w-container-max mx-auto gap-4">
        <div class="flex items-center gap-6 shrink-0">
          <a class="font-h2 text-h2 font-black tracking-tighter text-ai-cyan drop-shadow-[0_0_8px_rgba(6,182,212,0.5)]" href="/">
            Aether-Fi Docs
          </a>
          <nav class="hidden md:flex gap-6 h-full items-center">
            <a class="h-full flex items-center text-ai-cyan font-bold border-b-2 border-ai-cyan pb-1" href="/">Explorer</a>
          </nav>
        </div>
        <div class="hidden lg:block flex-1 max-w-xs">
          <SearchBarMini client:load />
        </div>
        <HeaderAuth client:load />
      </div>
    </header>
    <main class="flex-grow pt-[100px] pb-section-padding px-grid-gutter w-full max-w-container-max mx-auto">
      <slot />
    </main>
    <footer class="w-full py-section-padding bg-surface-container-lowest border-t border-white/5 mt-auto">
      <div class="flex flex-col md:flex-row justify-between items-center gap-element-gap px-grid-gutter max-w-container-max mx-auto">
        <div class="flex items-center gap-4">
          <span class="font-h2 text-h2 text-ai-purple">Aether-Fi Docs</span>
          <span class="font-body-md text-body-md text-text-secondary">
            © 2024 Aether-Fi Interdimensional. Secured by Quantum-Fintech Protocols.
          </span>
        </div>
      </div>
    </footer>
    <Chatbot client:load />
  </body>
</html>
