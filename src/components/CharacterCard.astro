---
const { character } = Astro.props;
const statusClass =
  character.status === 'Alive'
    ? 'bg-status-alive shadow-[0_0_5px_#10B981]'
    : character.status === 'Dead'
      ? 'bg-status-dead shadow-[0_0_5px_#EF4444]'
      : 'bg-status-unknown shadow-[0_0_5px_#F59E0B]';
const statusLabel = character.status === 'Alive' ? 'Vivo' : character.status === 'Dead' ? 'Muerto' : 'Desconocido';
---
<a
  class="group relative flex flex-col bg-surface-container/30 backdrop-blur-md border border-white/10 rounded-xl overflow-hidden hover:border-ai-cyan/50 hover:-translate-y-1 hover:shadow-[0_8px_30px_rgba(6,182,212,0.15)] transition-all duration-300 cursor-pointer"
  href={`/character/${character.id}`}
>
  <div class="h-48 w-full overflow-hidden relative border-b border-white/5">
    <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src={character.image} alt={character.name} loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-surface-container-lowest to-transparent opacity-80"></div>
    <div class="absolute top-3 right-3 flex items-center gap-1.5 bg-surface-container-lowest/80 backdrop-blur-sm border border-white/10 rounded-full px-2.5 py-1">
      <div class={`w-2 h-2 rounded-full ${statusClass}`}></div>
      <span class="font-label-sm text-[10px] uppercase text-text-primary tracking-wider">{statusLabel}</span>
    </div>
    <div class="absolute bottom-3 left-3">
      <span class="font-code-snippet text-xs text-ai-cyan bg-ai-cyan/10 border border-ai-cyan/20 px-2 py-0.5 rounded">
        ID: {character.id}
      </span>
    </div>
  </div>
  <div class="p-card-padding flex flex-col gap-2">
    <h3 class="font-h2 text-[20px] font-bold text-text-primary group-hover:text-ai-cyan transition-colors">
      {character.name}
    </h3>
    <div class="flex flex-col gap-1.5 mt-2">
      <div class="flex items-center justify-between text-sm">
        <span class="text-text-secondary font-body-md text-[13px]">Especie</span>
        <span class="text-text-primary font-body-md text-[13px]">{character.species}</span>
      </div>
      <div class="flex items-center justify-between text-sm">
        <span class="text-text-secondary font-body-md text-[13px]">Origen</span>
        <span class="text-text-primary font-body-md text-[13px] truncate max-w-[120px] text-right">
          {character.origin?.name ?? 'Desconocido'}
        </span>
      </div>
    </div>
  </div>
</a>
