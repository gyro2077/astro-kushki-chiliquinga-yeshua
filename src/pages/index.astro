---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import CharacterCard from '../components/CharacterCard.astro';
import SearchBar from '../components/SearchBar';

const res = await fetch('https://rickandmortyapi.com/api/character');
const data = await res.json();
const characters = data.results;
---
<Layout title="Aether-Fi Docs | Explorer">
  <section class="flex flex-col items-center justify-center text-center py-section-padding relative">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-ai-purple/10 rounded-full blur-[100px] -z-10 pointer-events-none"></div>
    <div class="absolute top-1/3 left-1/3 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-ai-cyan/10 rounded-full blur-[80px] -z-10 pointer-events-none"></div>
    <h1 class="font-h1 text-h1 mb-4 max-w-3xl bg-clip-text text-transparent bg-gradient-to-r from-ai-cyan via-white to-ai-purple drop-shadow-[0_0_20px_rgba(139,92,246,0.2)]">
      Portal de Exploracion Interdimensional
    </h1>
    <p class="font-body-lg text-body-lg text-text-secondary max-w-2xl mb-12">
      Documentacion interactiva de la API de Rick and Morty. Accede a endpoints, analiza protocolos y descubre entidades a traves de nuestro terminal cuantico.
    </p>
    <SearchBar client:load placeholder="Buscar personaje por ID..." />
  </section>

  <section class="mt-8">
    <div class="flex justify-between items-end mb-6">
      <div>
        <h2 class="font-h2 text-[24px] font-semibold text-text-primary mb-1">Entidades Detectadas</h2>
        <p class="font-body-md text-text-secondary text-[14px]">Monitoreo en tiempo real del multiverso.</p>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-grid-gutter">
      {characters.map((char) => (
        <CharacterCard character={char} />
      ))}
    </div>
  </section>
</Layout>
