---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Iniciar sesion | Aether-Fi Docs">
  <div class="max-w-md mx-auto glass-panel rounded-xl p-8">
    <h1 class="font-h2 text-[24px] text-text-primary mb-2">Iniciar sesion</h1>
    <p class="text-text-secondary mb-6 text-sm">
      Accede con tu correo verificado para ver el contenido completo.
    </p>
    <div class="space-y-4">
      <a
        class="w-full flex items-center justify-center gap-2 bg-primary-container text-on-primary-container px-4 py-2 rounded font-label-sm font-bold hover:opacity-90 transition-opacity"
        href="/api/auth/google"
      >
        Continuar con Google
      </a>
      <p class="text-text-secondary text-sm">
        El acceso se realiza solo con Gmail.
      </p>
    </div>
  </div>
</Layout>
